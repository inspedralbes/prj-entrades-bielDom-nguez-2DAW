# --- Nuxt (runtimeConfig.public) ---
# Aquests noms han de ser exactament NUXT_PUBLIC_* perquè Nuxt els exposi al client.

# API Laravel (des del navegador: localhost amb ports publicats al host)
NUXT_PUBLIC_API_URL=http://localhost:8000

# Només servidor Nuxt (SSR): URL interna cap a Laravel dins Docker (deixa buit en dev local sense compose)
# NUXT_API_INTERNAL_URL=http://backend-api:8000

# Socket.IO (mateix host, port del socket-server)
NUXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Google Maps JavaScript API (opcional; deixa buit si no uses el mapa de cerca)
# A Google Cloud → Credencials → la teva API key → «Restriccions d’aplicació» → referents HTTP:
# afegeix l’origen del Nuxt (p. ex. http://pulse.daw.inspedralbes.cat:3000/*). Sense això: RefererNotAllowedMapError.
NUXT_PUBLIC_GOOGLE_MAPS_KEY=
