APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Speckit / Docker: usar pgsql amb PostGIS al compose (vegeu docker/dev/docker-compose.yml)
# DB_CONNECTION=sqlite
DB_CONNECTION=pgsql
# API al host (php artisan serve) amb Postgres al port 5432 del host: 127.0.0.1
# API dins Docker: docker/dev/entrypoint-api.sh exporta DB_HOST=postgres (ignora aquest valor)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=esdeveniments
DB_USERNAME=esdeveniments
DB_PASSWORD=esdeveniments

TICKETMASTER_API_KEY=WXrtWLRrAetbPfcMJi5puxJd4a9YFA69

# Preu fix (EUR) per esdeveniments nous del sync Ticketmaster i fallback API /events/:id/price
ORDER_FIXED_EVENT_PRICE_EUR=20
# JWT d’API (HS256). Opcional si només tens APP_KEY: config/jwt.php fa fallback a APP_KEY.
# Mínim ~32 caràcters (exigència firebase/php-jwt per HS256); si és massa curt, /api/auth/register retorna 500.
JWT_SECRET=
JWT_TTL=86400
# TTL del JWT de cada entrada (QR); per defecte 900 (15 min)
JWT_TICKET_TTL=900

# Preu per seient (stub) per comandes pending_payment fins a tarifes per zona (T020)
ORDER_STUB_UNIT_PRICE=25.0

TICKETMASTER_DISABLED=false
TICKETMASTER_DISCOVERY_BASE_URL=https://app.ticketmaster.com/discovery/v2
# Sincronització Discovery → taules `venues` / `events` (comanda `ticketmaster:sync-events` + schedule diari)
TICKETMASTER_SYNC_COUNTRY=ES
TICKETMASTER_SYNC_PAGE_SIZE=100
TICKETMASTER_SYNC_MAX_PAGES=20
TICKETMASTER_SYNC_DAILY_AT=04:15

# Socket-server (config/services.php → socket): QR SVG + POST /internal/emit (SeatStatusUpdated).
# Dues situacions:
# - API dins Docker (compose): cal http://socket-server:3001 (el contenidor backend NO pot usar localhost:3001 per arribar al socket).
# - API al host (php artisan serve) amb socket a localhost: llavors http://127.0.0.1:3001 és correcte.
# El navegador/Nuxt usa NUXT_PUBLIC_SOCKET_URL (normalment http://localhost:3001); això és independent.
SOCKET_SERVER_INTERNAL_URL=http://localhost:3001
# Opcional: mateix secret que SOCKET_INTERNAL_SECRET al socket-server (rutes /internal/*). En dev sovint buit.
# Si el socket té secret i aquí no coincideix, /internal/emit retorna 403 i no arriben SeatStatusUpdated (reservats/venuts en temps real).
SOCKET_INTERNAL_SECRET=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# predis = sense extensió PHP (recomanat Docker dev). phpredis = cal `pecl install redis` a la imatge.
REDIS_CLIENT=predis
# Dins Docker, entrypoint exporta REDIS_HOST=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Opcional: buit per dev si vols claus Redis sense prefix Laravel (mapa seat-holds + KEYS). Docker compose fixa REDIS_PREFIX buit.
# REDIS_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
