PORT=3001
REDIS_URL=redis://redis:6379
# Ha de ser el mateix string que JWT_SECRET del backend-api que signa el login (no SOCKET_INTERNAL_SECRET).
JWT_SECRET=your_jwt_secret_change_me
# Opcional: protegeix /internal/emit i /internal/qr-svg (capçalera X-Internal-Secret)
SOCKET_INTERNAL_SECRET=

# URL interna de l’API Laravel (alliberament de holds en desconnexió del namespace /private)
LARAVEL_INTERNAL_API_URL=http://backend-api:8000
